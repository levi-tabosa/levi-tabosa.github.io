---
import '../styles/global.css';

const { title = "Levi Tabosa Costa e Silva - Portfólio" } = Astro.props;
---

<!DOCTYPE html>
<html lang="pt-BR" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    
    <!-- Theme Script to prevent flash of light/dark mode -->
    <script is:inline>
      (function() {
        const savedTheme = localStorage.getItem('portfolio-theme');
        const savedPalette = localStorage.getItem('portfolio-palette') || 'blue';
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        
        const theme = savedTheme || (prefersDark ? 'dark' : 'light');
        
        if (theme === 'dark') {
          document.documentElement.classList.add('dark-mode');
        } else {
          document.documentElement.classList.remove('dark-mode');
        }
        
        // Remove any existing theme- classes
        document.documentElement.className.split(' ').forEach(cls => {
          if (cls.startsWith('theme-')) {
            document.documentElement.classList.remove(cls);
          }
        });
        document.documentElement.classList.add('theme-' + savedPalette);
      })();
    </script>
    
    <!-- Preconnect to Google Fonts for Poppins and Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-gh-bg-primary text-gh-text min-h-screen flex flex-col transition-colors duration-200">
    <slot />
  </body>
</html>
